{
  "name": "kuwait-marketplace-backend",
  "version": "1.0.0",
  "description": "Kuwait Multi-Vendor Marketplace - Medusa Backend",
  "main": ".medusa/server/index.js",
  "scripts": {
    "dev": "medusa develop",
    "build": "medusa build",
    "start": "medusa start",
    "db:migrate": "medusa db:migrate",
    "db:generate": "medusa db:generate",
    "db:sync-links": "medusa db:sync-links",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "seed:products": "npx medusa exec ./src/scripts/seed-products.ts",
    "seed:shipping": "npx medusa exec ./src/scripts/seed-shipping-options.ts",
    "verify:cart": "npx tsx src/scripts/verify-cart-api.ts"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.0.0",
    "@medusajs/framework": "^2.0.0",
    "@medusajs/medusa": "^2.0.0",
    "@paypal/paypal-server-sdk": "^1.0.0",
    "twilio": "^5.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^22.19.7",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "yaml": "^2.3.4"
  },
  "engines": {
    "node": ">=20"
  }
}
