# Medusa Backend Environment Variables
# Copy this file to .env and fill in the values

# ===================
# Database
# ===================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa

# ===================
# Redis
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# Security (REQUIRED - Generate strong secrets!)
# ===================
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
COOKIE_SECRET=your-cookie-secret-at-least-32-characters-long

# ===================
# CORS Configuration
# ===================
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# ===================
# Admin Configuration
# ===================
MEDUSA_BACKEND_URL=http://localhost:9000
DISABLE_ADMIN=false

# ===================
# Worker Mode
# ===================
# Options: "shared" (default), "server", "worker"
WORKER_MODE=shared

# ===================
# Twilio SMS Notifications
# ===================
# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Use your Twilio phone number or Messaging Service SID
TWILIO_FROM_NUMBER=+1234567890

# ===================
# SendGrid Email (optional)
# ===================
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM=noreply@yourdomain.com

# ===================
# Stripe Payments (optional)
# ===================
# Get your API keys from: https://dashboard.stripe.com/test/apikeys
# Use sk_test_xxx for testing, sk_live_xxx for production
STRIPE_API_KEY=
# Webhook secret for verifying Stripe webhook events (optional but recommended)
# Create a webhook at: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=

# ===================
# PayPal Payments (optional)
# ===================
# Get credentials from: https://developer.paypal.com/dashboard/applications
# 1. Create an app in the PayPal Developer Dashboard
# 2. Copy the Client ID and Client Secret
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# Environment: "sandbox" for testing, "production" for live payments
# PAYPAL_ENVIRONMENT=sandbox
# Auto-capture: Set to "true" to capture payments immediately, "false" to authorize first
# PAYPAL_AUTO_CAPTURE=false
# Webhook ID for validating PayPal webhooks (optional, improves security)
# PAYPAL_WEBHOOK_ID=your_webhook_id

# ===================
# AWS S3 File Storage (optional)
# ===================
# S3_FILE_URL=https://bucket.s3.region.amazonaws.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_REGION=us-east-1
# S3_BUCKET=your-bucket-name
# S3_PREFIX=uploads
