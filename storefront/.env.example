# Medusa Backend URL
# In development: http://localhost:9000
# In production: Your Medusa Cloud URL (e.g., https://your-project.medusa.cloud)
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000

# Default Region ID
# Get this from your Medusa admin after creating regions
NEXT_PUBLIC_DEFAULT_REGION_ID=

# Optional: Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
